# Eggy Environment Variables Template
# -----------------------------------------------------------------------------
# Instructions:
# 1. Copy this file to '.env'
# 2. Add your real API keys below
# 3. DO NOT commit the resulting '.env' file to version control
# -----------------------------------------------------------------------------

# OpenRouter API Key (Create one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter Preferred Model
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
